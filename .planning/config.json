{
  "version": "1.0.0",
  "mode": "yolo",
  "granularity": "coarse",
  "parallelization": true,
  "commit_docs": true,
  "model_profile": "inherit",
  "project": {
    "code": "dev-fu",
    "title": "dev-fu / flu.sh"
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "auto_advance": false,
    "pattern_mapper": true,
    "ui_phase": true,
    "ui_safety_gate": true,
    "ai_integration_phase": true,
    "tdd_mode": false,
    "code_review": true,
    "code_review_depth": "deep",
    "ui_review": true,
    "research_before_questions": false,
    "skip_discuss": false,
    "use_worktrees": true
  },
  "intel": {
    "enabled": true
  },
  "graphify": {
    "enabled": true
  },
  "git": {
    "branching_strategy": "none",
    "quick_branch_template": null
  },
  "hooks": {
    "context_warnings": true,
    "workflow_guard": true
  },
  "sub_repos": []
}
